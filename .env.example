# Copy to .env for local-only secrets. Do not commit real values.

# Optional API key used by future syllabus-search or OCR helpers.
LANG_DRILL_API_KEY=replace-with-local-secret

# Optional default reminder channel identifier.
LANG_DRILL_REMINDER_CHANNEL=example-channel

# Optional Hugging Face upload target for scripts/publish_huggingface.py.
HF_REPO_ID=your-namespace/lang-drill-skill
HF_REPO_TYPE=model
